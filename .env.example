# AutoRip2MKV-Mac Apple Developer Credentials
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# Your Apple ID email address
APPLE_ID=your-apple-id@example.com

# App-specific password from https://appleid.apple.com
# (NOT your regular Apple ID password)
APPLE_ID_PASSWORD=your-app-specific-password

# Your Team ID from Apple Developer account
# Found at: https://developer.apple.com/account/#!/membership/
TEAM_ID=YOUR_TEAM_ID

# Optional: Path to specific certificate if you have multiple
# SIGNING_IDENTITY="Developer ID Application: Your Name (TEAM_ID)"